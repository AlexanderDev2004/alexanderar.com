---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { normalizeSlug } from "../lib/slug";

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });

const blogEntries = await getCollection('blogs');
const blogs = blogEntries
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map((entry) => ({
    title: entry.data.title,
    date: formatDate(entry.data.date),
    description: entry.data.description,
    tags: entry.data.tags,
    slug: normalizeSlug(entry.slug),
  }));

const tagCounts = blogs.reduce((acc, blog) => {
  (blog.tags ?? []).forEach((tag) => {
    const key = tag.toLowerCase().trim();
    if (!key) return;
    acc[key] = (acc[key] ?? 0) + 1;
  });

  return acc;
}, {} as Record<string, number>);

const sortedTags = Object.keys(tagCounts).sort((a, b) => {
  const countDiff = (tagCounts[b] ?? 0) - (tagCounts[a] ?? 0);
  return countDiff !== 0 ? countDiff : a.localeCompare(b);
});
---

<Layout>
  <div class="max-w-6xl mx-auto px-4 sm:px-5 md:px-6 py-8 md:py-11">
    <a href="/" class="back-link">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back
    </a>

    <header class="glass-panel rounded-2xl md:rounded-3xl p-5 sm:p-6 md:p-8 mt-5 md:mt-6">
      <h1 class="page-title">All Posts</h1>
      <p class="page-copy">
        A collection of thoughts, technical notes, and lessons learned while building software.
      </p>
    </header>

    <div class="mt-6 md:mt-7 space-y-6" id="allBlogsSearchApp">
      <div class="mb-6">
        <input
          id="blogSearchInput"
          type="text"
          placeholder="Find post...(start with # to find tags)"
          class="w-full px-3.5 sm:px-4 py-2.5 sm:py-3 border rounded-lg text-sm sm:text-base transition-colors"
          style="border-color: var(--surface-border); background: var(--surface-strong); color: var(--text-primary);"
        />

        <div id="activeTagsSection" class="mt-3 hidden">
          <div class="mt-3 flex items-center justify-between gap-3">
            <p class="text-xs uppercase tracking-wide muted-text">Active tags</p>
            <button
              id="clearTagsButton"
              type="button"
              class="text-xs muted-text hover:opacity-80 transition-colors"
            >
              Clear all
            </button>
          </div>
          <div id="activeTagsList" class="mt-2 flex flex-wrap gap-2"></div>
        </div>

        <div
          id="tagSuggestionPanel"
          class="mt-3 border rounded-xl shadow-sm overflow-hidden hidden"
          style="border-color: var(--surface-border); background: var(--surface-strong);"
        >
          <div class="px-4 py-2 text-xs uppercase tracking-wide muted-text">Recommended</div>
          <div id="tagSuggestionList" class="max-h-64 overflow-auto" style="border-top: 1px solid var(--surface-border);"></div>
        </div>
      </div>

      {blogs.length > 0 ? (
        <div id="blogsGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
          {blogs.map((blog) => (
            <article
              data-blog-card
              data-title={blog.title.toLowerCase()}
              data-description={blog.description.toLowerCase()}
              data-tags={(blog.tags ?? []).map((tag) => tag.toLowerCase().trim()).join(',')}
              class="surface-item rounded-lg p-3 sm:p-4 transition-all duration-200 pressable"
            >
              <div class="flex items-center gap-2 text-xs sm:text-sm muted-text mb-2">
                <iconify-icon icon="mdi:calendar" width="16" height="16"></iconify-icon>
                <span>{blog.date}</span>
              </div>

              <h3 class="text-base sm:text-lg font-bold accent-link mb-2 line-clamp-2">
                {blog.title}
              </h3>

              <p class="text-sm primary-text line-clamp-3 mb-3">
                {blog.description}
              </p>

              {blog.tags && blog.tags.length > 0 && (
                <div class="flex flex-wrap gap-1 mb-3">
                  {blog.tags.slice(0, 3).map((tag) => (
                    <span class="pill-chip text-[11px] sm:text-xs px-2 py-1">#{tag.toUpperCase()}</span>
                  ))}
                  {blog.tags.length > 3 && (
                    <span class="text-[11px] sm:text-xs muted-text px-2 py-1">+{blog.tags.length - 3}</span>
                  )}
                </div>
              )}

              <a
                href={`/blogs/${blog.slug}`}
                class="inline-flex items-center gap-2 accent-link font-medium text-xs sm:text-sm transition-colors"
              >
                Read More
                <iconify-icon icon="mdi:arrow-right" width="16" height="16"></iconify-icon>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-8">
          <p class="muted-text">No blog posts available yet.</p>
        </div>
      )}

      <div id="blogsNoResults" class="text-center py-8 hidden">
        <p class="muted-text">
          No posts found matching "<span id="noResultsQuery"></span>"
        </p>
      </div>
    </div>
  </div>

  {blogs.length > 0 && (
    <script is:inline define:vars={{ sortedTags, tagCounts }}>
      (() => {
        const searchInput = document.getElementById('blogSearchInput');
        const activeTagsSection = document.getElementById('activeTagsSection');
        const activeTagsList = document.getElementById('activeTagsList');
        const clearTagsButton = document.getElementById('clearTagsButton');
        const tagSuggestionPanel = document.getElementById('tagSuggestionPanel');
        const tagSuggestionList = document.getElementById('tagSuggestionList');
        const noResults = document.getElementById('blogsNoResults');
        const noResultsQuery = document.getElementById('noResultsQuery');
        const cards = Array.from(document.querySelectorAll('[data-blog-card]'));

        if (!searchInput || !activeTagsSection || !activeTagsList || !clearTagsButton || !tagSuggestionPanel || !tagSuggestionList || !noResults || !noResultsQuery || cards.length === 0) {
          return;
        }

        const selectedTags = new Set();

        const normalize = (value) => value.toLowerCase().trim();

        const renderActiveTags = () => {
          activeTagsList.innerHTML = '';

          selectedTags.forEach((tag) => {
            const chip = document.createElement('span');
            chip.className = 'pill-chip inline-flex items-center gap-2 px-3 py-1 rounded-full text-sm';

            const label = document.createElement('span');
            label.textContent = `#${tag.toUpperCase()}`;

            const removeButton = document.createElement('button');
            removeButton.type = 'button';
            removeButton.className = 'muted-text hover:opacity-80';
            removeButton.setAttribute('aria-label', `Remove ${tag}`);
            removeButton.textContent = '×';

            removeButton.addEventListener('click', () => {
              selectedTags.delete(tag);
              renderActiveTags();
              updateFilter();
            });

            chip.appendChild(label);
            chip.appendChild(removeButton);
            activeTagsList.appendChild(chip);
          });

          activeTagsSection.classList.toggle('hidden', selectedTags.size === 0);
        };

        const addTagFromQuery = () => {
          const inputValue = searchInput.value.trim();
          if (!inputValue.startsWith('#')) return false;

          const candidate = normalize(inputValue.replace(/^#+/, ''));
          if (!candidate || selectedTags.has(candidate) || !sortedTags.includes(candidate)) return false;

          selectedTags.add(candidate);
          searchInput.value = '#';
          renderActiveTags();
          return true;
        };

        const getTagSuggestions = () => {
          const query = normalize(searchInput.value);
          if (!query.startsWith('#')) return [];

          const tagQuery = normalize(query.replace(/^#+/, ''));

          return sortedTags
            .filter((tag) => (tagQuery.length === 0 || tag.startsWith(tagQuery)) && !selectedTags.has(tag))
            .slice(0, 10);
        };

        const renderSuggestions = () => {
          const query = normalize(searchInput.value);
          const isTagMode = query.startsWith('#');

          if (!isTagMode) {
            tagSuggestionPanel.classList.add('hidden');
            tagSuggestionList.innerHTML = '';
            return;
          }

          const suggestions = getTagSuggestions();
          tagSuggestionPanel.classList.remove('hidden');
          tagSuggestionList.innerHTML = '';

          if (suggestions.length === 0) {
            const emptyState = document.createElement('div');
            emptyState.className = 'px-4 py-2 text-sm muted-text';
            emptyState.textContent = 'No tags found';
            tagSuggestionList.appendChild(emptyState);
            return;
          }

          suggestions.forEach((tag, index) => {
            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'w-full flex items-center justify-between gap-3 text-left px-4 py-2 transition-colors';
            if (index < suggestions.length - 1) {
              button.style.borderBottom = '1px solid var(--surface-border)';
            }

            const label = document.createElement('span');
            label.className = 'primary-text';
            label.textContent = `#${tag.toUpperCase()}`;

            const count = document.createElement('span');
            count.className = 'text-xs muted-text';
            const resultCount = tagCounts[tag] ?? 0;
            count.textContent = `${resultCount} result${resultCount === 1 ? '' : 's'}`;

            button.appendChild(label);
            button.appendChild(count);

            button.addEventListener('click', () => {
              selectedTags.add(tag);
              searchInput.value = '#';
              renderActiveTags();
              updateFilter();
              searchInput.focus();
            });

            tagSuggestionList.appendChild(button);
          });
        };

        const updateFilter = () => {
          const query = normalize(searchInput.value);
          const selectedTagList = Array.from(selectedTags);
          const tagQuery = query.startsWith('#') ? normalize(query.replace(/^#+/, '')) : '';
          const textQuery = query.startsWith('#') ? '' : query;
          let visibleCount = 0;

          cards.forEach((card) => {
            const title = card.getAttribute('data-title') ?? '';
            const description = card.getAttribute('data-description') ?? '';
            const tags = (card.getAttribute('data-tags') ?? '').split(',').filter(Boolean);

            const matchesSelectedTags = selectedTagList.length > 0
              ? selectedTagList.some((tag) => tags.includes(tag))
              : true;

            const matchesTagQuery = selectedTagList.length > 0
              ? true
              : tagQuery.length > 0
                ? tags.some((tag) => tag.startsWith(tagQuery))
                : true;

            const matchesText = textQuery.length > 0
              ? title.includes(textQuery) || description.includes(textQuery)
              : true;

            const visible = matchesSelectedTags && matchesTagQuery && matchesText;
            card.style.display = visible ? '' : 'none';
            if (visible) visibleCount += 1;
          });

          const hasNoResults = visibleCount === 0;
          noResults.classList.toggle('hidden', !hasNoResults);
          noResultsQuery.textContent = searchInput.value.trim();

          renderSuggestions();
        };

        searchInput.addEventListener('input', updateFilter);

        searchInput.addEventListener('keydown', (event) => {
          if (event.key === 'Enter') {
            const added = addTagFromQuery();
            if (added) {
              event.preventDefault();
              updateFilter();
            }
          }

          if (event.key === 'Backspace' && searchInput.value.trim() === '#' && selectedTags.size > 0) {
            event.preventDefault();
            const values = Array.from(selectedTags);
            const lastTag = values[values.length - 1];
            selectedTags.delete(lastTag);
            renderActiveTags();
            updateFilter();
          }

          if ((event.key === ',' || event.key === ' ') && searchInput.value.trim().startsWith('#')) {
            const added = addTagFromQuery();
            if (added) {
              event.preventDefault();
              updateFilter();
            }
          }
        });

        clearTagsButton.addEventListener('click', () => {
          selectedTags.clear();
          renderActiveTags();
          updateFilter();
          searchInput.focus();
        });

        renderActiveTags();
        updateFilter();
      })();
    </script>
  )}
</Layout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.48rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .back-link:hover {
    color: var(--text-primary);
  }

  .page-title {
    margin: 0;
    font-size: clamp(1.72rem, 4.3vw, 2.8rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    font-weight: 780;
  }

  .page-copy {
    margin: 0.95rem 0 0;
    max-width: 46rem;
    color: var(--text-muted);
    line-height: 1.72;
    font-size: clamp(0.95rem, 2vw, 1.05rem);
  }
</style>
