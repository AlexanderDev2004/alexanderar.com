---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { normalizeSlug } from "../lib/slug";

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });

const normalize = (value: string) => value.toLowerCase().trim();

const stripMarkdown = (value: string) =>
  value
    .replace(/```[\s\S]*?```/g, ' ')
    .replace(/`[^`]*`/g, ' ')
    .replace(/!\[[^\]]*\]\([^)]+\)/g, ' ')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/^#{1,6}\s+/gm, ' ')
    .replace(/[*_~>-]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();

const blogEntries = await getCollection('blogs');
const blogs = blogEntries
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map((entry, index) => {
    const normalizedTags = (entry.data.tags ?? []).map((tag) => normalize(tag)).filter(Boolean);
    const bodyExcerpt = stripMarkdown(entry.body).slice(0, 1200);
    const searchCorpus = normalize([
      entry.data.title,
      entry.data.description,
      normalizedTags.join(' '),
      bodyExcerpt,
    ].join(' '));

    return {
      title: entry.data.title,
      date: formatDate(entry.data.date),
      description: entry.data.description,
      tags: entry.data.tags,
      normalizedTags,
      slug: normalizeSlug(entry.slug),
      searchCorpus,
      order: index,
    };
  });

const tagCounts = blogs.reduce((acc, blog) => {
  (blog.normalizedTags ?? []).forEach((tag) => {
    acc[tag] = (acc[tag] ?? 0) + 1;
  });

  return acc;
}, {} as Record<string, number>);

const sortedTags = Object.keys(tagCounts).sort((a, b) => {
  const countDiff = (tagCounts[b] ?? 0) - (tagCounts[a] ?? 0);
  return countDiff !== 0 ? countDiff : a.localeCompare(b);
});
---

<Layout>
  <div class="max-w-6xl mx-auto px-4 sm:px-5 md:px-6 py-8 md:py-11">
    <a href="/" class="back-link">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back
    </a>

    <header class="glass-panel rounded-2xl md:rounded-3xl p-5 sm:p-6 md:p-8 mt-5 md:mt-6">
      <h1 class="page-title">All Posts</h1>
      <p class="page-copy">
        A collection of thoughts, technical notes, and lessons learned while building software.
      </p>
    </header>

    <div class="mt-6 md:mt-7 space-y-6" id="allBlogsSearchApp">
      <div class="mb-6">
        <input
          id="blogSearchInput"
          type="text"
          placeholder="Find posts by title, tags, or content... (type # for tags)"
          class="w-full px-3.5 sm:px-4 py-2.5 sm:py-3 border rounded-lg text-sm sm:text-base transition-colors"
          style="border-color: var(--surface-border); background: var(--surface-strong); color: var(--text-primary);"
        />

        <p id="blogsResultCount" class="mt-2 text-xs sm:text-sm muted-text" aria-live="polite"></p>

        <div id="activeTagsSection" class="mt-3 hidden">
          <div class="mt-3 flex items-center justify-between gap-3">
            <p class="text-xs uppercase tracking-wide muted-text">Active tags</p>
            <button
              id="clearTagsButton"
              type="button"
              class="text-xs muted-text hover:opacity-80 transition-colors"
            >
              Clear all
            </button>
          </div>
          <div id="activeTagsList" class="mt-2 flex flex-wrap gap-2"></div>
        </div>

        <div
          id="tagSuggestionPanel"
          class="mt-3 border rounded-xl shadow-sm overflow-hidden hidden"
          style="border-color: var(--surface-border); background: var(--surface-strong);"
        >
          <div class="px-4 py-2 text-xs uppercase tracking-wide muted-text">Recommended (use up/down + Enter)</div>
          <div id="tagSuggestionList" class="max-h-64 overflow-auto" style="border-top: 1px solid var(--surface-border);"></div>
        </div>
      </div>

      {blogs.length > 0 ? (
        <div id="blogsGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
          {blogs.map((blog) => (
            <a
              href={`/blogs/${blog.slug}`}
              aria-label={`Read post: ${blog.title}`}
              data-blog-card
              data-title={blog.title.toLowerCase()}
              data-description={blog.description.toLowerCase()}
              data-tags={blog.normalizedTags.join(',')}
              data-search={blog.searchCorpus}
              data-order={blog.order}
              class="group surface-item rounded-lg p-3 sm:p-4 transition-all duration-200 pressable block no-underline"
            >
              <div class="flex items-center gap-2 text-xs sm:text-sm muted-text mb-2">
                <iconify-icon icon="mdi:calendar" width="16" height="16"></iconify-icon>
                <span>{blog.date}</span>
              </div>

              <h3 class="text-base sm:text-lg font-bold accent-link mb-2 line-clamp-2">
                {blog.title}
              </h3>

              <p class="text-sm primary-text line-clamp-3 mb-3">
                {blog.description}
              </p>

              {blog.tags && blog.tags.length > 0 && (
                <div class="flex flex-wrap gap-1 mb-3">
                  {blog.tags.slice(0, 3).map((tag) => (
                    <span class="pill-chip text-[11px] sm:text-xs px-2 py-1">#{tag.toUpperCase()}</span>
                  ))}
                  {blog.tags.length > 3 && (
                    <span class="text-[11px] sm:text-xs muted-text px-2 py-1">+{blog.tags.length - 3}</span>
                  )}
                </div>
              )}

              <span class="inline-flex items-center gap-2 accent-link font-medium text-xs sm:text-sm transition-colors">
                Read More
                <iconify-icon icon="mdi:arrow-right" width="16" height="16"></iconify-icon>
              </span>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-8">
          <p class="muted-text">Sorry, blog posts are not available.</p>
        </div>
      )}

      <div id="blogsNoResults" class="text-center py-8 hidden">
        <p class="muted-text">
          No posts found matching "<span id="noResultsQuery"></span>"
        </p>
      </div>
    </div>
  </div>

  {blogs.length > 0 && (
    <script is:inline define:vars={{ sortedTags, tagCounts }}>
      (() => {
        const searchInput = document.getElementById('blogSearchInput');
        const resultCount = document.getElementById('blogsResultCount');
        const activeTagsSection = document.getElementById('activeTagsSection');
        const activeTagsList = document.getElementById('activeTagsList');
        const clearTagsButton = document.getElementById('clearTagsButton');
        const tagSuggestionPanel = document.getElementById('tagSuggestionPanel');
        const tagSuggestionList = document.getElementById('tagSuggestionList');
        const blogsGrid = document.getElementById('blogsGrid');
        const noResults = document.getElementById('blogsNoResults');
        const noResultsQuery = document.getElementById('noResultsQuery');
        const cards = Array.from(document.querySelectorAll('[data-blog-card]'));

        if (!searchInput || !activeTagsSection || !activeTagsList || !clearTagsButton || !tagSuggestionPanel || !tagSuggestionList || !blogsGrid || !noResults || !noResultsQuery || cards.length === 0) {
          return;
        }

        const selectedTags = new Set();
        let currentSuggestions = [];
        let highlightedSuggestionIndex = -1;

        const normalize = (value) => value.toLowerCase().trim();
        const splitTokens = (value) => normalize(value).split(/\s+/).filter(Boolean);

        searchInput.setAttribute('aria-controls', 'tagSuggestionList');
        searchInput.setAttribute('aria-autocomplete', 'list');
        searchInput.setAttribute('aria-expanded', 'false');
        tagSuggestionList.setAttribute('role', 'listbox');

        const setTagModeInput = () => {
          searchInput.value = '#';
        };

        const clearSearchInput = () => {
          searchInput.value = '';
        };

        const hydrateStateFromUrl = () => {
          const params = new URLSearchParams(window.location.search);
          const queryParam = params.get('q');
          const tagsParam = params.get('tags');

          if (queryParam) {
            searchInput.value = queryParam;
          }

          if (tagsParam) {
            tagsParam
              .split(',')
              .map((tag) => normalize(tag))
              .filter((tag) => tag.length > 0 && sortedTags.includes(tag))
              .forEach((tag) => selectedTags.add(tag));
          }
        };

        const syncUrlState = () => {
          const params = new URLSearchParams(window.location.search);
          const queryValue = searchInput.value.trim();
          const selectedTagList = Array.from(selectedTags);

          if (queryValue.length > 0 && queryValue !== '#') {
            params.set('q', queryValue);
          } else {
            params.delete('q');
          }

          if (selectedTagList.length > 0) {
            params.set('tags', selectedTagList.join(','));
          } else {
            params.delete('tags');
          }

          const nextQuery = params.toString();
          const nextUrl = nextQuery.length > 0
            ? `${window.location.pathname}?${nextQuery}`
            : window.location.pathname;

          window.history.replaceState(null, '', nextUrl);
        };

        const getFilterLabel = () => {
          const rawQuery = searchInput.value.trim();
          const queryLabel = rawQuery.length > 0 && rawQuery !== '#' ? rawQuery : '';
          const selectedTagLabel = Array.from(selectedTags).map((tag) => `#${tag}`).join(', ');

          if (queryLabel && selectedTagLabel) return `${queryLabel} + ${selectedTagLabel}`;
          if (queryLabel) return queryLabel;
          if (selectedTagLabel) return selectedTagLabel;
          return 'all posts';
        };

        const applySuggestionHighlight = () => {
          const suggestionButtons = Array.from(tagSuggestionList.querySelectorAll('[data-tag-suggestion]'));

          if (highlightedSuggestionIndex < 0 || highlightedSuggestionIndex >= suggestionButtons.length) {
            searchInput.removeAttribute('aria-activedescendant');
          }

          suggestionButtons.forEach((button, index) => {
            const isActive = index === highlightedSuggestionIndex;
            const activeArrow = button.querySelector('[data-active-arrow]');

            button.style.background = isActive ? 'var(--surface)' : 'transparent';
            button.setAttribute('aria-selected', isActive ? 'true' : 'false');

            if (activeArrow) {
              activeArrow.style.visibility = isActive ? 'visible' : 'hidden';
            }

            if (isActive) {
              const optionId = button.getAttribute('id');
              if (optionId) {
                searchInput.setAttribute('aria-activedescendant', optionId);
              }

              button.scrollIntoView({ block: 'nearest' });
            }
          });
        };

        const moveSuggestionHighlight = (direction) => {
          const totalSuggestions = currentSuggestions.length;
          if (totalSuggestions === 0) return;

          if (highlightedSuggestionIndex === -1) {
            highlightedSuggestionIndex = direction > 0 ? 0 : totalSuggestions - 1;
          } else {
            highlightedSuggestionIndex = (highlightedSuggestionIndex + direction + totalSuggestions) % totalSuggestions;
          }

          applySuggestionHighlight();
        };

        const selectTag = (tag) => {
          selectedTags.add(tag);
          clearSearchInput();
          renderActiveTags();
          updateFilter();
          searchInput.focus();
        };

        const selectHighlightedSuggestion = () => {
          const candidate = currentSuggestions[highlightedSuggestionIndex];
          if (!candidate) return false;
          selectTag(candidate);
          return true;
        };

        const renderActiveTags = () => {
          activeTagsList.innerHTML = '';

          selectedTags.forEach((tag) => {
            const chip = document.createElement('span');
            chip.className = 'pill-chip inline-flex items-center gap-2 px-3 py-1 rounded-full text-sm';

            const label = document.createElement('span');
            label.textContent = `#${tag.toUpperCase()}`;

            const removeButton = document.createElement('button');
            removeButton.type = 'button';
            removeButton.className = 'muted-text hover:opacity-80';
            removeButton.setAttribute('aria-label', `Remove ${tag}`);
            removeButton.textContent = '×';

            removeButton.addEventListener('click', () => {
              selectedTags.delete(tag);
              renderActiveTags();
              updateFilter();
            });

            chip.appendChild(label);
            chip.appendChild(removeButton);
            activeTagsList.appendChild(chip);
          });

          activeTagsSection.classList.toggle('hidden', selectedTags.size === 0);
        };

        const addTagFromQuery = () => {
          const inputValue = searchInput.value.trim();
          if (!inputValue.startsWith('#')) return false;

          const candidate = normalize(inputValue.replace(/^#+/, ''));
          if (!candidate || selectedTags.has(candidate) || !sortedTags.includes(candidate)) return false;

          selectedTags.add(candidate);
          clearSearchInput();
          renderActiveTags();
          return true;
        };

        const getTagSuggestions = () => {
          const query = normalize(searchInput.value);
          if (!query.startsWith('#')) return [];

          const tagQuery = normalize(query.replace(/^#+/, ''));
          const availableTags = sortedTags.filter((tag) => !selectedTags.has(tag));

          if (tagQuery.length === 0) {
            return availableTags.slice(0, 10);
          }

          const prefixMatches = availableTags.filter((tag) => tag.startsWith(tagQuery));
          const containsMatches = availableTags.filter((tag) => !prefixMatches.includes(tag) && tag.includes(tagQuery));

          return [...prefixMatches, ...containsMatches].slice(0, 10);
        };

        const renderSuggestions = () => {
          const query = normalize(searchInput.value);
          const isTagMode = query.startsWith('#');
          searchInput.setAttribute('aria-expanded', isTagMode ? 'true' : 'false');

          if (!isTagMode) {
            tagSuggestionPanel.classList.add('hidden');
            tagSuggestionList.innerHTML = '';
            currentSuggestions = [];
            highlightedSuggestionIndex = -1;
            searchInput.removeAttribute('aria-activedescendant');
            return;
          }

          const suggestions = getTagSuggestions();
          const previousActiveTag = currentSuggestions[highlightedSuggestionIndex] ?? '';

          currentSuggestions = suggestions;
          if (currentSuggestions.length === 0) {
            highlightedSuggestionIndex = -1;
          } else {
            const keepIndex = currentSuggestions.indexOf(previousActiveTag);
            highlightedSuggestionIndex = keepIndex >= 0 ? keepIndex : 0;
          }

          tagSuggestionPanel.classList.remove('hidden');
          tagSuggestionList.innerHTML = '';

          if (suggestions.length === 0) {
            const emptyState = document.createElement('div');
            emptyState.className = 'px-4 py-2 text-sm muted-text';
            emptyState.textContent = 'No tags found';
            tagSuggestionList.appendChild(emptyState);
            searchInput.removeAttribute('aria-activedescendant');
            return;
          }

          suggestions.forEach((tag, index) => {
            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'w-full flex items-center justify-between gap-3 text-left px-4 py-2 transition-colors';
            button.id = `tagSuggestionOption${index}`;
            button.setAttribute('role', 'option');
            button.setAttribute('data-tag-suggestion', 'true');
            if (index < suggestions.length - 1) {
              button.style.borderBottom = '1px solid var(--surface-border)';
            }

            const label = document.createElement('span');
            label.className = 'primary-text';
            label.textContent = `#${tag.toUpperCase()}`;

            const count = document.createElement('span');
            count.className = 'text-xs muted-text';
            const resultCount = tagCounts[tag] ?? 0;
            count.textContent = `${resultCount} result${resultCount === 1 ? '' : 's'}`;

            const countAndArrow = document.createElement('span');
            countAndArrow.className = 'inline-flex items-center gap-2';

            const activeArrow = document.createElement('span');
            activeArrow.className = 'text-xs muted-text';
            activeArrow.textContent = '<-';
            activeArrow.style.visibility = 'hidden';
            activeArrow.setAttribute('data-active-arrow', 'true');

            countAndArrow.appendChild(count);
            countAndArrow.appendChild(activeArrow);

            button.appendChild(label);
            button.appendChild(countAndArrow);

            button.addEventListener('mouseenter', () => {
              highlightedSuggestionIndex = index;
              applySuggestionHighlight();
            });

            button.addEventListener('click', () => {
              selectTag(tag);
            });

            tagSuggestionList.appendChild(button);
          });

          applySuggestionHighlight();
        };

        const updateFilter = () => {
          const query = normalize(searchInput.value);
          const selectedTagList = Array.from(selectedTags);
          const isTagMode = query.startsWith('#');
          const tagQuery = isTagMode ? normalize(query.replace(/^#+/, '')) : '';
          const textQuery = isTagMode ? '' : query;
          const textTokens = splitTokens(textQuery);
          const visibleCards = [];

          cards.forEach((card) => {
            const title = card.getAttribute('data-title') ?? '';
            const description = card.getAttribute('data-description') ?? '';
            const searchCorpus = card.getAttribute('data-search') ?? `${title} ${description}`;
            const tags = (card.getAttribute('data-tags') ?? '').split(',').filter(Boolean);
            const order = Number.parseInt(card.getAttribute('data-order') ?? '0', 10);

            const matchesSelectedTags = selectedTagList.length > 0
              ? selectedTagList.every((tag) => tags.includes(tag))
              : true;

            const matchesTagQuery = selectedTagList.length > 0
              ? true
              : tagQuery.length > 0
                ? tags.some((tag) => tag.includes(tagQuery))
                : true;

            const matchesText = textTokens.length > 0
              ? textTokens.every((token) => searchCorpus.includes(token))
              : true;

            const visible = matchesSelectedTags && matchesTagQuery && matchesText;

            if (!visible) {
              card.style.display = 'none';
              return;
            }

            let relevanceScore = 0;

            textTokens.forEach((token) => {
              if (title.includes(token)) relevanceScore += 8;
              if (tags.some((tag) => tag.includes(token))) relevanceScore += 6;
              if (description.includes(token)) relevanceScore += 4;
              if (searchCorpus.includes(token)) relevanceScore += 2;
            });

            if (selectedTagList.length > 0) {
              relevanceScore += selectedTagList.length * 10;
            }

            if (isTagMode && tagQuery.length > 0 && tags.some((tag) => tag.startsWith(tagQuery))) {
              relevanceScore += 3;
            }

            visibleCards.push({
              card,
              order,
              relevanceScore,
            });
          });

          visibleCards
            .sort((a, b) => {
              const scoreDiff = b.relevanceScore - a.relevanceScore;
              if (scoreDiff !== 0) return scoreDiff;
              return a.order - b.order;
            })
            .forEach(({ card }) => {
              card.style.display = '';
              blogsGrid.appendChild(card);
            });

          const visibleCount = visibleCards.length;

          const hasNoResults = visibleCount === 0;
          noResults.classList.toggle('hidden', !hasNoResults);
          noResultsQuery.textContent = getFilterLabel();

          if (resultCount) {
            const inputValue = searchInput.value.trim();
            const queryText = inputValue.length > 0 && inputValue !== '#'
              ? ` for "${inputValue}"`
              : '';
            const tagText = selectedTags.size > 0
              ? ` with ${selectedTags.size} active tag${selectedTags.size === 1 ? '' : 's'}`
              : '';
            resultCount.textContent = `${visibleCount} post${visibleCount === 1 ? '' : 's'} found${queryText}${tagText}.`;
          }

          renderSuggestions();
          syncUrlState();
        };

        searchInput.addEventListener('input', () => {
          updateFilter();
        });

        searchInput.addEventListener('keydown', (event) => {
          const isTagInputMode = searchInput.value.trim().startsWith('#');

          if (event.key === '#' && !isTagInputMode) {
            event.preventDefault();
            setTagModeInput();
            updateFilter();
            return;
          }

          if (isTagInputMode && event.key === 'ArrowDown') {
            event.preventDefault();
            moveSuggestionHighlight(1);
            return;
          }

          if (isTagInputMode && event.key === 'ArrowUp') {
            event.preventDefault();
            moveSuggestionHighlight(-1);
            return;
          }

          if (isTagInputMode && event.key === 'Escape') {
            highlightedSuggestionIndex = -1;
            applySuggestionHighlight();
            return;
          }

          if (event.key === 'Enter') {
            if (isTagInputMode && selectHighlightedSuggestion()) {
              event.preventDefault();
              return;
            }

            const added = addTagFromQuery();
            if (added) {
              event.preventDefault();
              updateFilter();
            }
          }

          if (event.key === 'Backspace' && searchInput.value.trim() === '#' && selectedTags.size > 0) {
            event.preventDefault();
            const values = Array.from(selectedTags);
            const lastTag = values[values.length - 1];
            selectedTags.delete(lastTag);
            renderActiveTags();
            updateFilter();
          }

          if ((event.key === ',' || event.key === ' ') && searchInput.value.trim().startsWith('#')) {
            const added = addTagFromQuery();
            if (added) {
              event.preventDefault();
              updateFilter();
            }
          }
        });

        clearTagsButton.addEventListener('click', () => {
          selectedTags.clear();
          renderActiveTags();
          updateFilter();
          searchInput.focus();
        });

        hydrateStateFromUrl();
        renderActiveTags();
        updateFilter();
      })();
    </script>
  )}
</Layout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.48rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .back-link:hover {
    color: var(--text-primary);
  }

  .page-title {
    margin: 0;
    font-size: clamp(1.72rem, 4.3vw, 2.8rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    font-weight: 780;
  }

  .page-copy {
    margin: 0.95rem 0 0;
    max-width: 46rem;
    color: var(--text-muted);
    line-height: 1.72;
    font-size: clamp(0.95rem, 2vw, 1.05rem);
  }
</style>
