---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { normalizeSlug } from '../../lib/slug';

export const prerender = true;

export async function getStaticPaths() {
  const projectEntries = await getCollection('projects');

  return projectEntries.map((entry) => ({
    params: { slug: normalizeSlug(entry.slug) },
    props: {
      entrySlug: entry.slug,
    },
  }));
}

const projectEntries = await getCollection('projects');
const requestedSlug = Astro.params.slug ?? '';
const preloadedSlug = Astro.props.entrySlug;

const project = preloadedSlug
  ? projectEntries.find((entry) => entry.slug === preloadedSlug)
  : projectEntries.find((entry) => normalizeSlug(entry.slug) === normalizeSlug(requestedSlug));

if (!project) {
  throw new Error(`Project not found: ${Astro.params.slug}`);
}

const { Content } = await project.render();
---

<Layout title={`${project.data.title} - Project`} description={project.data.description}>
  <div class="container mx-auto px-4 sm:px-5 md:px-6 py-8 md:py-11 max-w-5xl expand-reveal">
    <a href="/all-projects" class="back-link">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to Projects
    </a>

    <article class="mt-5 md:mt-6 space-y-5 md:space-y-6">
      <header class="glass-panel rounded-2xl md:rounded-3xl p-5 sm:p-6 md:p-8">
        <div class="flex flex-wrap items-end gap-3 md:gap-4">
          <h1 class="project-title">{project.data.title}</h1>
          <span class="year-pill">{project.data.year}</span>
        </div>
        <p class="mt-4 text-sm sm:text-base md:text-[1.05rem] muted-text leading-relaxed">
          {project.data.fullDescription}
        </p>

        <div class="mt-5 flex flex-wrap gap-2.5 sm:gap-3">
          {project.data.projectLink && (
            <a
              href={project.data.projectLink}
              target="_blank"
              rel="noopener noreferrer"
              class="action-link action-link--primary"
            >
              <span>View Project</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          )}

          {project.data.repoLink && (
            <a
              href={project.data.repoLink}
              target="_blank"
              rel="noopener noreferrer"
              class="action-link"
            >
              <span>View Repository</span>
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
              </svg>
            </a>
          )}
        </div>
      </header>

      {project.data.image && (
        <div class="section-shell rounded-2xl md:rounded-3xl p-2 sm:p-3">
          <img src={project.data.image} alt={project.data.title} class="project-hero" />
        </div>
      )}

      {project.data.technologies && project.data.technologies.length > 0 && (
        <section class="section-shell rounded-2xl md:rounded-3xl p-5 sm:p-6">
          <h2 class="stack-title">Tech Stack</h2>
          <div class="mt-4 flex flex-wrap gap-2.5">
            {project.data.technologies.map((tech) => (
              <a
                href={tech.docLink}
                target="_blank"
                rel="noopener noreferrer"
                class="tech-chip"
                title={`Learn more about ${tech.name}`}
              >
                <iconify-icon icon={tech.icon} width="20" height="20"></iconify-icon>
                <span>{tech.name}</span>
              </a>
            ))}
          </div>
        </section>
      )}

      <section class="section-shell rounded-2xl md:rounded-3xl p-5 sm:p-6 md:p-7">
        <div class="project-prose prose dark:prose-invert max-w-none">
          <Content />
        </div>
      </section>
    </article>
  </div>
</Layout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.48rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .back-link:hover {
    color: var(--text-primary);
  }

  .project-title {
    margin: 0;
    font-size: clamp(1.65rem, 4.4vw, 2.8rem);
    line-height: 1.08;
    font-weight: 780;
    letter-spacing: -0.03em;
    color: var(--text-primary);
  }

  .year-pill {
    border-radius: 999px;
    border: 1px solid var(--surface-border);
    background: var(--accent-soft);
    color: var(--text-primary);
    font-size: 0.78rem;
    font-weight: 700;
    padding: 0.35rem 0.72rem;
  }

  .action-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border-radius: 0.78rem;
    border: 1px solid var(--surface-border-soft);
    background: var(--surface-strong);
    color: var(--text-primary);
    padding: 0.6rem 0.9rem;
    font-size: 0.82rem;
    font-weight: 650;
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }

  .action-link:hover {
    transform: translateY(-1px);
    border-color: var(--accent);
    background: var(--accent-soft);
  }

  .action-link--primary {
    border-color: var(--accent);
    background: var(--accent-soft);
  }

  :global(.prose h2) {
    font-size: 1.72rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  :global(.prose h3) {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  :global(.prose p) {
    line-height: 1.625;
    margin-bottom: 1rem;
  }

  :global(.prose ul) {
    list-style-type: disc;
    list-style-position: inside;
    margin-bottom: 1rem;
  }

  :global(.prose li) {
    margin-top: 0.5rem;
  }

  :global(.prose strong) {
    font-weight: 700;
  }

  :global(.project-prose a) {
    color: var(--accent-strong);
    text-decoration: underline;
    text-underline-offset: 0.14em;
    text-decoration-thickness: 0.09em;
    font-weight: 600;
    transition: color 0.2s ease;
  }

  :global(.project-prose a:hover) {
    color: var(--text-primary);
  }

  :global(.project-prose a:visited) {
    color: var(--accent);
  }

  :global(.project-prose a:focus-visible) {
    outline: 2px solid currentColor;
    outline-offset: 2px;
    border-radius: 0.2rem;
  }

  .stack-title {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.2;
    font-weight: 700;
    color: var(--text-primary);
  }

  .tech-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--surface-border);
    border-radius: 0.72rem;
    background: var(--surface);
    color: var(--text-primary);
    font-size: 0.82rem;
    font-weight: 600;
    padding: 0.52rem 0.8rem;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .tech-chip:hover {
    border-color: var(--accent);
    background: var(--accent-soft);
  }

  .project-hero {
    max-width: 100%;
    max-height: 70vh;
    width: 100%;
    height: auto;
    margin: 0;
    object-fit: contain;
    border-radius: 0.95rem;
    border: 1px solid var(--surface-border);
    background: rgba(15, 23, 42, 0.35);
  }

  @media (min-width: 640px) {
    .action-link {
      font-size: 0.86rem;
      padding: 0.63rem 1rem;
    }
  }

  @media (min-width: 768px) {
    .project-hero {
      border-radius: 1.1rem;
    }
  }
</style>
