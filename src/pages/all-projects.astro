---
import Layout from '../layouts/Layout.astro';
import ProjectsGrid from '../components/ProjectsGrid.svelte';
import { getCollection } from 'astro:content';
import { normalizeSlug } from '../lib/slug';

const projectEntries = await getCollection('projects');

const parseYear = (value: string) => Number.parseInt(value, 10) || 0;

const projects = projectEntries
  .map((entry) => ({
    slug: normalizeSlug(entry.slug),
    title: entry.data.title,
    year: entry.data.year,
    description: entry.data.description,
    image: entry.data.image,
    technologies: entry.data.technologies,
  }))
  .sort((a, b) => {
    const yearOrder = parseYear(b.year) - parseYear(a.year);
    if (yearOrder !== 0) return yearOrder;
    return a.title.localeCompare(b.title);
  });
---

<Layout>
  <div class="container mx-auto px-4 sm:px-5 md:px-6 py-8 md:py-11 max-w-6xl">
    <a href="/" class="back-link">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back
    </a>

    <header class="glass-panel rounded-2xl md:rounded-3xl p-5 sm:p-6 md:p-8 mt-5 md:mt-6">
      <h1 class="page-title">Personal Projects</h1>
      <p class="page-copy">
        A curated set of products and experiments that helped me sharpen engineering and product thinking.
      </p>
    </header>

    <div class="mt-6 md:mt-7">
      <ProjectsGrid client:load items={projects} />
    </div>
  </div>
</Layout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.48rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .back-link:hover {
    color: var(--text-primary);
  }

  .page-title {
    margin: 0;
    font-size: clamp(1.8rem, 4.5vw, 3rem);
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    font-weight: 780;
  }

  .page-copy {
    margin: 0.95rem 0 0;
    max-width: 46rem;
    color: var(--text-muted);
    line-height: 1.72;
    font-size: clamp(0.95rem, 2.1vw, 1.08rem);
  }
</style>
