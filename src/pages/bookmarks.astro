---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const formatDate = (date?: Date) => {
  if (!date) return null;
  return date.toLocaleDateString('en-US', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
};

const bookmarkEntries = await getCollection('bookmarks');

const bookmarks = bookmarkEntries
  .sort((a, b) => (b.data.date?.valueOf() ?? 0) - (a.data.date?.valueOf() ?? 0))
  .map((entry) => ({
    slug: entry.slug,
    title: entry.data.title,
    description: entry.data.description,
    date: formatDate(entry.data.date),
    tags: entry.data.tags ?? [],
  }));
---

<Layout
  title="Bookmarks Vault"
  description="Secret bookmarks and notes by Alexander Agung Raya."
  robots="noindex, nofollow"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-5 md:px-6 py-8 md:py-12">
    <a
      href="/"
      class="inline-flex items-center gap-2 text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white mb-8"
      style="font-family: 'Plus Jakarta Sans', sans-serif;"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back
    </a>

    <div class="mb-8 md:mb-10">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-2">
        Bookmarks
      </h1>
      <p class="text-base sm:text-lg text-gray-600 dark:text-gray-400">
        Notes and references from markdown files.
      </p>
    </div>

    {bookmarks.length === 0 ? (
      <div class="border border-gray-300 dark:border-gray-700 rounded-lg p-5 text-gray-600 dark:text-gray-400">
        No bookmark notes yet. Add a new file in <code>src/content/bookmarks/</code>.
      </div>
    ) : (
      <div class="space-y-4">
        {bookmarks.map((item, index) => (
          <a
            href={`/bookmarks/${item.slug}`}
            class="block border border-gray-300 dark:border-gray-700 rounded-lg p-4 sm:p-5 hover:bg-gray-50 dark:hover:bg-gray-900 transition-colors reveal pressable"
            style={`--reveal-delay: ${index}`}
          >
            <div class="flex items-start justify-between gap-3">
              <h2 class="text-lg sm:text-xl font-bold text-gray-900 dark:text-white">{item.title}</h2>
              {item.date && (
                <span class="text-xs sm:text-sm text-gray-500 dark:text-gray-400 whitespace-nowrap">
                  {item.date}
                </span>
              )}
            </div>

            {item.description && (
              <p class="mt-2 text-sm sm:text-base text-gray-600 dark:text-gray-400 line-clamp-2">
                {item.description}
              </p>
            )}

            {item.tags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-2">
                {item.tags.map((tag) => (
                  <span class="text-xs px-2 py-1 border border-gray-400 dark:border-gray-600 rounded text-gray-700 dark:text-gray-300">
                    #{tag}
                  </span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    )}
  </div>
</Layout>
