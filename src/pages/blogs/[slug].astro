---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { normalizeSlug } from '../../lib/slug';

export const prerender = true;

export async function getStaticPaths() {
  const blogEntries = await getCollection('blogs');

  return blogEntries.map((entry) => ({
    params: { slug: normalizeSlug(entry.slug) },
    props: {
      entrySlug: entry.slug,
    },
  }));
}

const blogEntries = await getCollection('blogs');
const requestedSlug = Astro.params.slug ?? '';
const preloadedSlug = Astro.props.entrySlug;

const blog = preloadedSlug
  ? blogEntries.find((entry) => entry.slug === preloadedSlug)
  : blogEntries.find((entry) => normalizeSlug(entry.slug) === normalizeSlug(requestedSlug));

if (!blog) {
  throw new Error(`Blog post not found: ${Astro.params.slug}`);
}

const { Content } = await blog.render();

// GitHub edit link
const githubRepo = 'AlexanderDev2004/alexanderar.com';
const githubBranch = 'master';
const editLink = `https://github.com/${githubRepo}/edit/${githubBranch}/src/content/blogs/${blog.slug}.md`;
---

<Layout>
  <div class="reading-progress" aria-hidden="true">
    <div class="reading-progress__bar" id="readingProgressBar"></div>
  </div>
  <div class="max-w-4xl mx-auto px-4 sm:px-5 md:px-6 py-8 md:py-11">
    <!-- Back Button -->
    <a
      href="/all-blogs"
      class="back-link mb-8"
    >
      <iconify-icon icon="mdi:arrow-left" width="20" height="20"></iconify-icon>
      Back to Posts
    </a>

    <!-- Header -->
    <article class="space-y-6 expand-reveal">
      <header class="glass-panel rounded-2xl p-5 sm:p-6 md:p-7 space-y-4 border-b pb-8" style="border-color: var(--surface-border);">
        <div class="flex items-start justify-between gap-4">
          <h1 class="text-4xl font-bold primary-text flex-1">
            {blog.data.title}
          </h1>
          <a
            href={editLink}
            target="_blank"
            rel="noopener noreferrer"
            title="Edit this post on GitHub"
            class="flex items-center gap-2 px-3 py-2 text-sm font-medium rounded-lg transition-colors whitespace-nowrap muted-text"
            style="border: 1px solid var(--surface-border); background: var(--surface);"
          >
            <iconify-icon icon="mdi:github" width="18" height="18"></iconify-icon>
            <span class="hidden sm:inline">Edit</span>
          </a>
        </div>

        <div class="flex items-center gap-4 muted-text">
          <div class="flex items-center gap-2">
            <iconify-icon icon="mdi:calendar" width="18" height="18"></iconify-icon>
            <span>
              {blog.data.date.toLocaleDateString('en-US', {
                day: 'numeric',
                month: 'long',
                year: 'numeric',
              })}
            </span>
          </div>
        </div>

        <!-- Tags -->
        {blog.data.tags && blog.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 pt-4">
            {blog.data.tags.map((tag) => (
              <span class="pill-chip px-3 py-1 rounded-full text-sm font-medium">
                #{tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <!-- Content -->
      <div class="section-shell rounded-2xl p-5 sm:p-6 blog-prose prose dark:prose-invert max-w-none">
        <Content />
      </div>

      <!-- Comments -->
      <section class="section-shell rounded-2xl p-5 sm:p-6 comments-shell space-y-3">
        <h2 class="text-lg sm:text-xl font-bold primary-text">Comments</h2>

        <script
          src="https://giscus.app/client.js"
          data-repo="AlexanderDev2004/alexanderar.com"
          data-repo-id="R_kgDORIJATw"
          data-category="General"
          data-category-id="DIC_kwDORIJAT84C4xSq"
          data-mapping="specific"
          data-term={`src/content/blogs/${blog.slug}.md`}
          data-strict="1"
          data-reactions-enabled="1"
          data-emit-metadata="0"
          data-input-position="top"
          data-theme="preferred_color_scheme"
          data-lang="en"
          data-loading="lazy"
          crossorigin="anonymous"
          async
        ></script>

        <p class="text-sm muted-text">
          If you don&apos;t see comment section, please turn off your adblock :)
        </p>
      </section>

      <!-- Footer -->
      <footer class="border-t pt-8 mt-12" style="border-color: var(--surface-border);">
        <a
          href="/all-blogs"
          class="back-link"
        >
          ← Back to All Posts
        </a>
      </footer>
    </article>
  </div>
  <script is:inline>
    const progressBar = document.getElementById('readingProgressBar');
    const updateProgress = () => {
      if (!progressBar) return;
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? Math.min(scrollTop / docHeight, 1) : 0;
      progressBar.style.transform = `scaleX(${progress})`;
    };

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(() => {
        updateProgress();
        ticking = false;
      });
    };

    updateProgress();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', updateProgress);
  </script>
</Layout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--text-muted);
    font-weight: 600;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--text-primary);
  }

  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: rgba(148, 163, 184, 0.2);
    z-index: 60;
  }

  .reading-progress__bar {
    height: 100%;
    width: 100%;
    transform: scaleX(0);
    transform-origin: left;
    background: linear-gradient(90deg, #38bdf8, #3b82f6);
    transition: transform 0.08s ease-out;
  }

  :global(html.dark) .reading-progress {
    background: rgba(148, 163, 184, 0.18);
  }

  :global(.blog-prose a) {
    color: #2563eb;
    text-decoration: underline;
    text-underline-offset: 0.14em;
    text-decoration-thickness: 0.09em;
    font-weight: 600;
    transition: color 0.2s ease;
  }

  :global(.blog-prose a:hover) {
    color: #1d4ed8;
  }

  :global(.blog-prose a:visited) {
    color: #1e40af;
  }

  :global(.blog-prose a:focus-visible) {
    outline: 2px solid currentColor;
    outline-offset: 2px;
    border-radius: 0.2rem;
  }

  :global(html.dark .blog-prose a) {
    color: #60a5fa;
  }

  :global(html.dark .blog-prose a:hover) {
    color: #93c5fd;
  }

  :global(html.dark .blog-prose a:visited) {
    color: #3b82f6;
  }

  :global(.comments-shell .giscus),
  :global(.comments-shell .giscus-frame) {
    width: 100%;
  }
</style>
