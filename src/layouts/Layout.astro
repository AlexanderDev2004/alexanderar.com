---
import "../styles/global.css";
import Header from '../components/Header.svelte';
import Footer from '../components/Footer.svelte';

interface LayoutProps {
  title?: string;
  description?: string;
  robots?: string;
  ogImagePath?: string;
}

const {
  title = 'Alexander Agung Raya - Software Developer',
  description = 'Portfolio of Alexander Agung Raya, a Software Developer from Indonesia.',
  robots = 'index, follow',
  ogImagePath = '/IconAlex.png',
} = Astro.props as LayoutProps;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
const ogImage = new URL(ogImagePath, Astro.site ?? Astro.url);
---

<!doctype html>
<html lang="en" class="scroll-smooth dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/IconAlex.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalURL.toString()} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:image" content={ogImage.toString()} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.toString()} />
    <script is:inline src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"></script>
  </head>
  <body class="transition-colors duration-300 antialiased">
    <div class="page-atmosphere" aria-hidden="true">
      <span class="page-grid-pattern"></span>
      <span class="page-vignette"></span>
    </div>
    <Header client:load />
    <main class="relative z-10">
      <slot />
    </main>
    <div class="relative z-10">
      <Footer />
    </div>
    <script is:inline>
      const formatCodeLanguage = (value) => {
        if (!value) return 'Code';
        const normalized = value.toLowerCase();
        const aliases = {
          sh: 'Bash',
          shell: 'Bash',
          bash: 'Bash',
          zsh: 'Zsh',
          fish: 'Fish',
          ksh: 'KornShell',
          csh: 'C Shell',
          tcsh: 'TC Shell',
          console: 'Shell',
          terminal: 'Shell',
          ps1: 'PowerShell',
          pwsh: 'PowerShell',
          powershell: 'PowerShell',
          cmd: 'Batch',
          bat: 'Batch',
          dos: 'Batch',

          js: 'JavaScript',
          jsx: 'JavaScript JSX',
          mjs: 'JavaScript',
          cjs: 'JavaScript',
          node: 'Node.js',
          nodejs: 'Node.js',
          ts: 'TypeScript',
          tsx: 'TypeScript JSX',
          mts: 'TypeScript',
          cts: 'TypeScript',

          py: 'Python',

          html: 'HTML',
          htm: 'HTML',
          xml: 'XML',
          xhtml: 'XHTML',
          svg: 'SVG',
          css: 'CSS',
          scss: 'SCSS',
          sass: 'Sass',
          less: 'Less',
          styl: 'Stylus',
          postcss: 'PostCSS',

          yml: 'YAML',
          yaml: 'YAML',
          md: 'Markdown',
          markdown: 'Markdown',
          mdx: 'MDX',
          diff: 'Diff',
          patch: 'Patch',
          rst: 'reStructuredText',
          adoc: 'AsciiDoc',
          asciidoc: 'AsciiDoc',
          tex: 'TeX',
          latex: 'LaTeX',

          json: 'JSON',
          jsonc: 'JSONC',
          json5: 'JSON5',
          toml: 'TOML',
          ini: 'INI',
          conf: 'Config',
          cfg: 'Config',
          dotenv: 'dotenv',
          env: 'dotenv',
          properties: 'Properties',
          csv: 'CSV',
          tsv: 'TSV',

          sql: 'SQL',
          mysql: 'MySQL SQL',
          postgresql: 'PostgreSQL SQL',
          postgres: 'PostgreSQL SQL',
          pgsql: 'PostgreSQL SQL',
          plsql: 'PL/SQL',
          tsql: 'T-SQL',
          graphql: 'GraphQL',
          gql: 'GraphQL',
          sparql: 'SPARQL',

          c: 'C',
          h: 'C Header',
          cpp: 'C++',
          cxx: 'C++',
          cc: 'C++',
          'c++': 'C++',
          hpp: 'C++ Header',
          hxx: 'C++ Header',
          objc: 'Objective-C',
          'objective-c': 'Objective-C',
          m: 'MATLAB/Objective-C',
          objcpp: 'Objective-C++',
          mm: 'Objective-C++',
          'objective-cpp': 'Objective-C++',
          cs: 'C#',
          csharp: 'C#',
          'c#': 'C#',
          fs: 'F#',
          fsharp: 'F#',
          'f#': 'F#',
          vb: 'Visual Basic .NET',
          vbnet: 'Visual Basic .NET',

          java: 'Java',
          kotlin: 'Kotlin',
          kt: 'Kotlin',
          kts: 'Kotlin Script',
          scala: 'Scala',
          groovy: 'Groovy',
          gradle: 'Gradle',
          clj: 'Clojure',
          cljs: 'ClojureScript',
          cljc: 'Clojure',
          clojure: 'Clojure',

          rb: 'Ruby',
          ruby: 'Ruby',
          php: 'PHP',
          r: 'R',
          rscript: 'R',
          jl: 'Julia',
          julia: 'Julia',
          pl: 'Perl',
          pm: 'Perl',
          perl: 'Perl',
          lua: 'Lua',
          tcl: 'Tcl',

          go: 'Go',
          golang: 'Go',
          rs: 'Rust',
          rust: 'Rust',
          zig: 'Zig',
          nim: 'Nim',
          odin: 'Odin',
          d: 'D',
          swift: 'Swift',
          dart: 'Dart',

          hs: 'Haskell',
          haskell: 'Haskell',
          ml: 'OCaml/ML',
          mli: 'OCaml Interface',
          ocaml: 'OCaml',
          reason: 'ReasonML',
          elm: 'Elm',
          erl: 'Erlang',
          erlang: 'Erlang',
          ex: 'Elixir',
          exs: 'Elixir',
          elixir: 'Elixir',
          lisp: 'Lisp',
          cl: 'Common Lisp',
          'common-lisp': 'Common Lisp',
          scheme: 'Scheme',
          scm: 'Scheme',
          racket: 'Racket',

          fortran: 'Fortran',
          f90: 'Fortran',
          f95: 'Fortran',
          f03: 'Fortran',
          ada: 'Ada',
          pascal: 'Pascal',
          delphi: 'Delphi',
          cobol: 'COBOL',
          prolog: 'Prolog',
          smalltalk: 'Smalltalk',

          asm: 'Assembly',
          s: 'Assembly',
          nasm: 'NASM',
          masm: 'MASM',
          armasm: 'ARM Assembly',
          wasm: 'WebAssembly',
          wat: 'WebAssembly Text',
          wgsl: 'WGSL',
          glsl: 'GLSL',
          hlsl: 'HLSL',

          matlab: 'MATLAB',
          octave: 'GNU Octave',
          sas: 'SAS',
          stata: 'Stata',

          docker: 'Dockerfile',
          dockerfile: 'Dockerfile',
          make: 'Makefile',
          makefile: 'Makefile',
          cmake: 'CMake',
          ninja: 'Ninja Build',
          meson: 'Meson',
          bazel: 'Bazel',
          bzl: 'Starlark',
          starlark: 'Starlark',
          nix: 'Nix',
          tf: 'Terraform',
          terraform: 'Terraform',
          hcl: 'HCL',
          cue: 'CUE',
          ansible: 'Ansible',
          nginx: 'Nginx',
          apacheconf: 'Apache Config',

          proto: 'Protocol Buffers',
          protobuf: 'Protocol Buffers',
          thrift: 'Thrift',
          avro: 'Avro',
          openapi: 'OpenAPI',
          swagger: 'Swagger',

          solidity: 'Solidity',
          sol: 'Solidity',
          vyper: 'Vyper',
          move: 'Move',
          cadence: 'Cadence',

          gdscript: 'GDScript',
          shaderlab: 'ShaderLab',
        };
        return aliases[normalized] ?? (normalized.charAt(0).toUpperCase() + normalized.slice(1));
      };

      const normalizeNewlines = (value) => value.replace(/\r\n/g, '\n').replace(/\r/g, '\n');

      const parseDiffHunk = (line) => {
        const match = line.match(/^@@\s*-(\d+)(?:,\d+)?\s+\+(\d+)(?:,\d+)?\s*@@/);
        if (!match) return null;

        return {
          oldStart: Number.parseInt(match[1], 10),
          newStart: Number.parseInt(match[2], 10),
        };
      };

      const classifyDiffLine = (line) => {
        if (line.startsWith('@@')) return 'hunk';
        if (line.startsWith('diff ') || line.startsWith('index ') || line.startsWith('--- ') || line.startsWith('+++ ') || line.startsWith('\\ ')) {
          return 'meta';
        }
        if (line.startsWith('+')) return 'added';
        if (line.startsWith('-')) return 'removed';
        return 'context';
      };

      const extractAddedDiffLines = (rawCode) => {
        const normalizedCode = normalizeNewlines(rawCode);
        const lines = normalizedCode.split('\n');

        return lines
          .filter((line) => classifyDiffLine(line) === 'added')
          .map((line) => line.slice(1))
          .join('\n');
      };

      const createDiffView = (rawCode) => {
        const container = document.createElement('div');
        container.className = 'code-diff-view';

        const linesList = document.createElement('ol');
        linesList.className = 'code-diff-lines';

        const normalizedCode = normalizeNewlines(rawCode);
        const lines = normalizedCode.split('\n');

        if (lines.length > 1 && lines[lines.length - 1] === '') {
          lines.pop();
        }

        if (lines.length === 0) {
          lines.push('');
        }

        let oldLineNumber = 1;
        let newLineNumber = 1;

        lines.forEach((line) => {
          const lineType = classifyDiffLine(line);

          const row = document.createElement('li');
          row.className = `code-diff-line code-diff-line--${lineType}`;

          const oldNumber = document.createElement('span');
          oldNumber.className = 'code-diff-line-no code-diff-line-no--old';

          const newNumber = document.createElement('span');
          newNumber.className = 'code-diff-line-no code-diff-line-no--new';

          if (lineType === 'hunk') {
            const hunk = parseDiffHunk(line);
            if (hunk) {
              oldLineNumber = hunk.oldStart;
              newLineNumber = hunk.newStart;
            }
          } else if (lineType === 'removed') {
            oldNumber.textContent = String(oldLineNumber);
            oldLineNumber += 1;
          } else if (lineType === 'added') {
            newNumber.textContent = String(newLineNumber);
            newLineNumber += 1;
          } else if (lineType === 'context') {
            oldNumber.textContent = String(oldLineNumber);
            newNumber.textContent = String(newLineNumber);
            oldLineNumber += 1;
            newLineNumber += 1;
          }

          const lineCode = document.createElement('code');
          lineCode.className = 'code-diff-line-code';
          lineCode.textContent = line.length > 0 ? line : ' ';

          row.appendChild(oldNumber);
          row.appendChild(newNumber);
          row.appendChild(lineCode);
          linesList.appendChild(row);
        });

        container.appendChild(linesList);
        return container;
      };

      const addCopyButtons = () => {
        document.querySelectorAll('pre').forEach((block) => {
          if (block.closest('.code-block-wrap')) return;

          const codeEl = block.querySelector('code');
          const className = codeEl?.className ?? '';
          const languageClass = className
            .split(' ')
            .find((entry) => entry.startsWith('language-'));
          const languageId = languageClass?.replace('language-', '').toLowerCase() ?? '';
          const language = formatCodeLanguage(languageId);
          const isDiffBlock = languageId === 'diff' || languageId === 'patch';

          const wrapper = document.createElement('div');
          wrapper.className = 'code-block-wrap';

          const toolbar = document.createElement('div');
          toolbar.className = 'code-block-toolbar';

          const toolbarActions = document.createElement('div');
          toolbarActions.className = 'code-toolbar-actions';

          const languageBadge = document.createElement('span');
          languageBadge.className = 'code-language';
          languageBadge.innerHTML = '<span class="code-language-icon">&lt;/&gt;</span><span>' + language + '</span>';

          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'code-copy-button';
          button.setAttribute('aria-label', isDiffBlock ? 'Copy added lines' : 'Copy code');
          button.innerHTML = 'Copy';

          button.addEventListener('click', async () => {
            const rawCode = codeEl?.textContent ?? '';
            const copyAddedOnly = isDiffBlock && wrapper.classList.contains('is-diff-enhanced');
            const code = copyAddedOnly ? extractAddedDiffLines(rawCode) : rawCode;
            try {
              await navigator.clipboard.writeText(code);
              button.innerHTML = 'Copied';
              button.classList.add('copied');
              setTimeout(() => {
                button.innerHTML = 'Copy';
                button.classList.remove('copied');
              }, 2000);
            } catch {
              button.innerHTML = 'Failed';
              setTimeout(() => {
                button.innerHTML = 'Copy';
              }, 2000);
            }
          });

          const parent = block.parentNode;
          if (!parent) return;
          parent.insertBefore(wrapper, block);
          wrapper.appendChild(toolbar);
          wrapper.appendChild(block);

          if (isDiffBlock) {
            wrapper.classList.add('code-block-wrap--diff', 'is-diff-enhanced');
            block.classList.add('code-diff-source');

            const rawCode = codeEl?.textContent ?? block.textContent ?? '';
            const diffView = createDiffView(rawCode);
            wrapper.appendChild(diffView);

            const diffToggleButton = document.createElement('button');
            diffToggleButton.type = 'button';
            diffToggleButton.className = 'code-diff-toggle';
            diffToggleButton.setAttribute('aria-label', 'Toggle diff styled view');
            diffToggleButton.setAttribute('aria-pressed', 'true');
            diffToggleButton.textContent = 'Diff view: on';

            diffToggleButton.addEventListener('click', () => {
              const isEnhanced = wrapper.classList.toggle('is-diff-enhanced');
              diffToggleButton.setAttribute('aria-pressed', isEnhanced ? 'true' : 'false');
              diffToggleButton.textContent = isEnhanced ? 'Diff view: on' : 'Diff view: off';
              button.setAttribute('aria-label', isEnhanced ? 'Copy added lines' : 'Copy full diff block');
            });

            toolbarActions.appendChild(diffToggleButton);
          }

          toolbarActions.appendChild(button);
          toolbar.appendChild(languageBadge);
          toolbar.appendChild(toolbarActions);
        });
      };

      const enhanceRichMedia = () => {
        document.querySelectorAll('.prose iframe, .prose video, .prose audio').forEach((media) => {
          if (!(media instanceof HTMLElement)) return;
          if (media.closest('.media-card-wrap')) return;

          const wrapper = document.createElement('div');
          wrapper.className = 'media-card-wrap';

          const parent = media.parentNode;
          if (!parent) return;
          parent.insertBefore(wrapper, media);

          if (media.tagName.toLowerCase() === 'iframe') {
            const frame = document.createElement('div');
            frame.className = 'media-frame';
            wrapper.appendChild(frame);
            frame.appendChild(media);

            media.setAttribute('loading', media.getAttribute('loading') ?? 'lazy');
            media.removeAttribute('width');
            media.removeAttribute('height');
            media.classList.add('media-embed');
            return;
          }

          if (media.tagName.toLowerCase() === 'video') {
            if (!media.getAttribute('controls')) media.setAttribute('controls', '');
            media.setAttribute('preload', media.getAttribute('preload') ?? 'metadata');
            media.classList.add('media-video');
            wrapper.appendChild(media);
            return;
          }

          media.classList.add('media-audio');
          wrapper.appendChild(media);
        });
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
          addCopyButtons();
          enhanceRichMedia();
        });
      } else {
        addCopyButtons();
        enhanceRichMedia();
      }
    </script>
    <script is:inline>
      if ('startViewTransition' in document) {
        document.addEventListener('click', (event) => {
          const target = event.target;
          const link = target instanceof Element ? target.closest('a[href]') : null;
          if (!link) return;
          const href = link.getAttribute('href');
          if (!href || href.startsWith('#')) return;
          if (link.target === '_blank') return;
          if (href.startsWith('http') && !href.startsWith(window.location.origin)) return;

          event.preventDefault();
          document.startViewTransition(() => {
            window.location.href = link.href;
          });
        });
      }
    </script>
  </body>
</html>

<style>
  html {
    font-family: "Plus Jakarta Sans", sans-serif;
  }

  .page-atmosphere {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .page-grid-pattern {
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 5px,
        rgba(129, 140, 248, 0.14) 5px,
        rgba(129, 140, 248, 0.14) 6px,
        transparent 6px,
        transparent 15px
      ),
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 5px,
        rgba(129, 140, 248, 0.14) 5px,
        rgba(129, 140, 248, 0.14) 6px,
        transparent 6px,
        transparent 15px
      ),
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 10px,
        rgba(56, 189, 248, 0.1) 10px,
        rgba(56, 189, 248, 0.1) 11px,
        transparent 11px,
        transparent 30px
      ),
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 10px,
        rgba(56, 189, 248, 0.1) 10px,
        rgba(56, 189, 248, 0.1) 11px,
        transparent 11px,
        transparent 30px
      );
  }

  .page-vignette {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(120% 75% at 50% 120%, rgba(2, 6, 23, 0.7), transparent 64%),
      radial-gradient(90% 50% at 50% -10%, rgba(30, 41, 59, 0.3), transparent 66%);
  }

  @media (max-width: 768px) {
    .page-grid-pattern {
      opacity: 0.9;
    }
  }
</style>

