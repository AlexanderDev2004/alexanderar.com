---
import "../styles/global.css";
import Header from '../components/Header.svelte';
import Footer from '../components/Footer.svelte';

interface LayoutProps {
  title?: string;
  description?: string;
  robots?: string;
  ogImagePath?: string;
}

const {
  title = 'Alexander Agung Raya - Software Developer',
  description = 'Portfolio of Alexander Agung Raya, a Software Developer from Indonesia.',
  robots = 'index, follow',
  ogImagePath = '/IconAlex.png',
} = Astro.props as LayoutProps;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
const ogImage = new URL(ogImagePath, Astro.site ?? Astro.url);
---

<!doctype html>
<html lang="en" class="scroll-smooth dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/IconAlex.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalURL.toString()} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:image" content={ogImage.toString()} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage.toString()} />
    <script is:inline src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"></script>
  </head>
  <body class="transition-colors duration-300 antialiased">
    <div class="page-atmosphere" aria-hidden="true">
      <span class="page-grid-pattern"></span>
      <span class="page-vignette"></span>
    </div>
    <Header client:load />
    <main class="relative z-10">
      <slot />
    </main>
    <div class="relative z-10">
      <Footer />
    </div>
    <script is:inline>
      const formatCodeLanguage = (value) => {
        if (!value) return 'Code';
        const normalized = value.toLowerCase();
        const aliases = {
          sh: 'Bash',
          shell: 'Bash',
          zsh: 'Bash',
          console: 'Bash',
          js: 'JavaScript',
          ts: 'TypeScript',
          py: 'Python',
          yml: 'YAML',
          md: 'Markdown',
        };
        return aliases[normalized] ?? (normalized.charAt(0).toUpperCase() + normalized.slice(1));
      };

      const addCopyButtons = () => {
        document.querySelectorAll('pre').forEach((block) => {
          if (block.closest('.code-block-wrap')) return;

          const codeEl = block.querySelector('code');
          const className = codeEl?.className ?? '';
          const languageClass = className
            .split(' ')
            .find((entry) => entry.startsWith('language-'));
          const language = formatCodeLanguage(languageClass?.replace('language-', ''));

          const wrapper = document.createElement('div');
          wrapper.className = 'code-block-wrap';

          const toolbar = document.createElement('div');
          toolbar.className = 'code-block-toolbar';

          const languageBadge = document.createElement('span');
          languageBadge.className = 'code-language';
          languageBadge.innerHTML = '<span class="code-language-icon">&lt;/&gt;</span><span>' + language + '</span>';

          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'code-copy-button';
          button.setAttribute('aria-label', 'Copy code');
          button.innerHTML = 'Copy';

          button.addEventListener('click', async () => {
            const code = codeEl?.innerText ?? '';
            try {
              await navigator.clipboard.writeText(code);
              button.innerHTML = 'Copied';
              button.classList.add('copied');
              setTimeout(() => {
                button.innerHTML = 'Copy';
                button.classList.remove('copied');
              }, 2000);
            } catch {
              button.innerHTML = 'Failed';
              setTimeout(() => {
                button.innerHTML = 'Copy';
              }, 2000);
            }
          });

          const parent = block.parentNode;
          if (!parent) return;
          parent.insertBefore(wrapper, block);
          wrapper.appendChild(toolbar);
          wrapper.appendChild(block);

          toolbar.appendChild(languageBadge);
          toolbar.appendChild(button);
        });
      };

      const enhanceRichMedia = () => {
        document.querySelectorAll('.prose iframe, .prose video, .prose audio').forEach((media) => {
          if (!(media instanceof HTMLElement)) return;
          if (media.closest('.media-card-wrap')) return;

          const wrapper = document.createElement('div');
          wrapper.className = 'media-card-wrap';

          const parent = media.parentNode;
          if (!parent) return;
          parent.insertBefore(wrapper, media);

          if (media.tagName.toLowerCase() === 'iframe') {
            const frame = document.createElement('div');
            frame.className = 'media-frame';
            wrapper.appendChild(frame);
            frame.appendChild(media);

            media.setAttribute('loading', media.getAttribute('loading') ?? 'lazy');
            media.removeAttribute('width');
            media.removeAttribute('height');
            media.classList.add('media-embed');
            return;
          }

          if (media.tagName.toLowerCase() === 'video') {
            if (!media.getAttribute('controls')) media.setAttribute('controls', '');
            media.setAttribute('preload', media.getAttribute('preload') ?? 'metadata');
            media.classList.add('media-video');
            wrapper.appendChild(media);
            return;
          }

          media.classList.add('media-audio');
          wrapper.appendChild(media);
        });
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
          addCopyButtons();
          enhanceRichMedia();
        });
      } else {
        addCopyButtons();
        enhanceRichMedia();
      }
    </script>
    <script is:inline>
      if ('startViewTransition' in document) {
        document.addEventListener('click', (event) => {
          const target = event.target;
          const link = target instanceof Element ? target.closest('a[href]') : null;
          if (!link) return;
          const href = link.getAttribute('href');
          if (!href || href.startsWith('#')) return;
          if (link.target === '_blank') return;
          if (href.startsWith('http') && !href.startsWith(window.location.origin)) return;

          event.preventDefault();
          document.startViewTransition(() => {
            window.location.href = link.href;
          });
        });
      }
    </script>
  </body>
</html>

<style>
  html {
    font-family: "Plus Jakarta Sans", sans-serif;
  }

  .page-atmosphere {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .page-grid-pattern {
    position: absolute;
    inset: 0;
    background-image:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 5px,
        rgba(129, 140, 248, 0.14) 5px,
        rgba(129, 140, 248, 0.14) 6px,
        transparent 6px,
        transparent 15px
      ),
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 5px,
        rgba(129, 140, 248, 0.14) 5px,
        rgba(129, 140, 248, 0.14) 6px,
        transparent 6px,
        transparent 15px
      ),
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 10px,
        rgba(56, 189, 248, 0.1) 10px,
        rgba(56, 189, 248, 0.1) 11px,
        transparent 11px,
        transparent 30px
      ),
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 10px,
        rgba(56, 189, 248, 0.1) 10px,
        rgba(56, 189, 248, 0.1) 11px,
        transparent 11px,
        transparent 30px
      );
  }

  .page-vignette {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(120% 75% at 50% 120%, rgba(2, 6, 23, 0.7), transparent 64%),
      radial-gradient(90% 50% at 50% -10%, rgba(30, 41, 59, 0.3), transparent 66%);
  }

  @media (max-width: 768px) {
    .page-grid-pattern {
      opacity: 0.9;
    }
  }
</style>

